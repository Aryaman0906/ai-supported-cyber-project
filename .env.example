# Optional external threat-intelligence API keys.
VIRUSTOTAL_API_KEY=
PHISHTANK_API_KEY=

# Cloud Run / Gmail Security Bot settings. Placeholder values only; never commit real secrets.
ENVIRONMENT=development
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
CLOUD_RUN_BASE_URL=https://your-cloud-run-service-url
GMAIL_OAUTH_REDIRECT_URI=https://your-cloud-run-service-url/gmail/auth/callback
GMAIL_PUBSUB_TOPIC=projects/your-gcp-project-id/topics/gmail-security-bot
GOOGLE_OAUTH_CLIENT_SECRET_JSON={"web":{"client_id":"placeholder","client_secret":"placeholder","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","redirect_uris":["https://your-cloud-run-service-url/gmail/auth/callback"]}}
GOOGLE_OAUTH_CLIENT_SECRET_NAME=projects/your-gcp-project-id/secrets/google-oauth-client/versions/latest
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key-from-python--cryptography-fernet-generate-key
PUBSUB_PUSH_TOKEN=replace-with-random-shared-token
TASK_SHARED_SECRET=replace-with-random-task-secret
STORE_EMAIL_PREVIEWS=false
STORAGE_BACKEND=memory
LOCAL_STORAGE_PATH=.local/gmail_bot_storage.json
DRIVE_REPORT_FOLDER_NAME=AI Cyber Reports
REPORT_OUTPUT_DIR=reports/generated
GMAIL_BOT_USER_EMAIL=user@example.com

# Local FastAPI polling dashboard protection. Placeholder only; never commit a real token.
LOCAL_ADMIN_TOKEN=replace-with-random-local-admin-token
